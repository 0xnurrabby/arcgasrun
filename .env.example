# Neon PostgreSQL
DATABASE_URL=postgresql://neondb_owner:PASSWORD@HOST/neondb?sslmode=require

# Arc Testnet
ARC_RPC_URL=https://rpc.testnet.arc.network
USDC_ADDRESS=0x3600000000000000000000000000000000000000
ADMIN_ADDRESS=0xe8Bda2Ed9d2FC622D900C8a76dc455A3e79B041f

# Contract addresses (filled after deploy)
VAULT_ADDRESS=
SCORE_ADDRESS=

# Operator key (pays out USDC withdraws) — same as deployer key by default
OPERATOR_PRIVATE_KEY=
DEPLOYER_PRIVATE_KEY=
# Optional: if vault owner is not operator, set owner key for admin_withdraw API
OWNER_PRIVATE_KEY=

# Optional
NEYNAR_API_KEY=
MAINTENANCE_MODE=false
